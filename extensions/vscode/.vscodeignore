# Keep the VSIX small and self-contained: ship out/extension.js + bin/ only.
.vscode/**
.gitignore
src/**
scripts/**
node_modules/**
# package.mjs emits a self-contained extension.js bundle. Excluding the rest of
# out/ prevents stale tsc modules from being accidentally shipped in the VSIX.
out/**
!out/extension.js
tsconfig.json
pnpm-lock.yaml
**/*.ts
*.vsix
